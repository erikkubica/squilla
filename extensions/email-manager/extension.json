{
    "name": "Email Manager",
    "slug": "email-manager",
    "version": "1.0.0",
    "author": "Squilla",
    "description": "Manage email templates, rules, delivery logs, and provider settings.",
    "provides": ["email-management"],
    "auto_activate": true,
    "capabilities": [
        "data:read",
        "data:write",
        "data:delete",
        "settings:read",
        "settings:write",
        "events:subscribe",
        "log:write"
    ],
    "data_owned_tables": [
        "email_templates",
        "email_rules",
        "email_logs",
        "email_layouts"
    ],
    "admin_routes": [
        { "method": "GET",  "path": "/logs",        "required_capability": "view_email_logs" },
        { "method": "GET",  "path": "/logs/**",     "required_capability": "view_email_logs" },
        { "method": "*",    "path": "/templates",     "required_capability": "manage_email" },
        { "method": "*",    "path": "/templates/**",  "required_capability": "manage_email" },
        { "method": "*",    "path": "/layouts",       "required_capability": "manage_email" },
        { "method": "*",    "path": "/layouts/**",    "required_capability": "manage_email" },
        { "method": "*",    "path": "/rules",         "required_capability": "manage_email" },
        { "method": "*",    "path": "/rules/**",      "required_capability": "manage_email" },
        { "method": "*",    "path": "/settings",      "required_capability": "manage_email" },
        { "method": "*",    "path": "/settings/**",   "required_capability": "manage_email" }
    ],
    "plugins": [
        {
            "binary": "bin/email-manager",
            "events": ["*"]
        }
    ],
    "admin_ui": {
        "entry": "admin-ui/dist/index.js",
        "capabilities": [
            {
                "key": "manage_email",
                "label": "Manage Email",
                "description": "Edit email templates, layouts, rules, and provider settings."
            },
            {
                "key": "view_email_logs",
                "label": "View Email Logs",
                "description": "Read the email delivery log without granting template / rule write access."
            }
        ],
        "routes": [
            {"path": "/templates", "component": "EmailTemplates"},
            {"path": "/templates/new", "component": "EmailTemplateEditor"},
            {"path": "/templates/:id", "component": "EmailTemplateEditor"},
            {"path": "/layouts", "component": "EmailBaseLayout"},
            {"path": "/rules", "component": "EmailRules"},
            {"path": "/rules/new", "component": "EmailRuleEditor"},
            {"path": "/rules/:id", "component": "EmailRuleEditor"},
            {"path": "/logs", "component": "EmailLogs"},
            {"path": "/settings", "component": "EmailSettings"}
        ],
        "menu": {
            "label": "Email",
            "icon": "Mail",
            "position": "6",
            "section": "settings",
            "required_capability": "manage_email",
            "children": [
                {"label": "Templates", "route": "/admin/ext/email-manager/templates", "icon": "LayoutTemplate"},
                {"label": "Layouts", "route": "/admin/ext/email-manager/layouts", "icon": "Layout"},
                {"label": "Rules", "route": "/admin/ext/email-manager/rules", "icon": "Gavel"},
                {"label": "Logs", "route": "/admin/ext/email-manager/logs", "icon": "ScrollText", "required_capability": "view_email_logs"},
                {"label": "Settings", "route": "/admin/ext/email-manager/settings", "icon": "Settings"}
            ]
        }
    }
}
