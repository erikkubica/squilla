{
  "name": "Forms",
  "slug": "forms",
  "version": "2.0.0",
  "author": "Squilla",
  "description": "Production-grade form builder with file uploads, CAPTCHA, conditional logic, webhooks, GDPR compliance, and email notifications.",
  "provides": ["forms"],
  "auto_activate": true,
  "capabilities": [
    "data:read",
    "data:write",
    "data:delete",
    "email:send",
    "settings:read",
    "log:write",
    "files:write",
    "files:delete",
    "http:fetch",
    "events:emit",
    "users:read"
  ],
  "data_owned_tables": [
    "forms",
    "form_submissions",
    "form_webhook_logs"
  ],
  "blocks": [{ "slug": "vibe-form", "dir": "vibe-form" }],
  "plugins": [
    {
      "binary": "bin/forms",
      "events": []
    }
  ],
  "public_routes": [{ "method": "POST", "path": "/forms/submit/*" }],
  "admin_routes": [
    { "method": "*", "path": "/forms",       "required_capability": "manage_forms" },
    { "method": "*", "path": "/forms/**",    "required_capability": "manage_forms" },
    { "method": "*", "path": "/submissions",     "required_capability": "manage_forms" },
    { "method": "*", "path": "/submissions/**",  "required_capability": "manage_forms" }
  ],
  "admin_ui": {
    "entry": "admin-ui/dist/index.js",
    "capabilities": [
      {
        "key": "manage_forms",
        "label": "Manage Forms",
        "description": "Create and edit form definitions; view, export, and delete submissions."
      }
    ],
    "routes": [
      { "path": "/", "component": "FormsList" },
      { "path": "/new", "component": "FormEditor" },
      { "path": "/edit/:id", "component": "FormEditor" },
      { "path": "/submissions", "component": "SubmissionsList" },
      { "path": "/submissions/:id", "component": "SubmissionDetail" }
    ],
    "menu": {
      "label": "Forms",
      "icon": "FormInput",
      "section": "content",
      "position": "4",
      "required_capability": "manage_forms"
    },
    "field_types": [
      {
        "type": "form_selector",
        "label": "Form Selector",
        "description": "Select a form from the Forms extension",
        "icon": "ClipboardList",
        "group": "Forms",
        "component": "FormFieldSelector"
      }
    ]
  }
}
