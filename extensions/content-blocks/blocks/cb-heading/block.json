{
  "slug": "cb-heading",
  "label": "Heading",
  "icon": "type",
  "description": "A standalone heading block for creating visual section breaks and hierarchy. Renders a configurable heading (h1-h6) with optional subtitle and decorative divider. Use to introduce new page sections or add prominent titles. Layout: heading text with optional subtitle, configurable alignment, optional decorative element.",
  "field_schema": [
    {
      "label": "Heading Text",
      "type": "text",
      "required": true,
      "key": "text"
    },
    {
      "label": "Subtitle",
      "type": "text",
      "required": false,
      "key": "subtitle"
    },
    {
      "label": "Heading Level",
      "type": "select",
      "options": [
        "h1",
        "h2",
        "h3",
        "h4",
        "h5",
        "h6"
      ],
      "default": "h2",
      "key": "level"
    },
    {
      "label": "Alignment",
      "type": "select",
      "options": [
        "left",
        "center",
        "right"
      ],
      "default": "center",
      "key": "alignment"
    },
    {
      "label": "Divider Style",
      "type": "select",
      "options": [
        "line",
        "dots",
        "none"
      ],
      "default": "line",
      "key": "divider"
    }
  ],
  "test_data": {
    "text": "Our Services",
    "subtitle": "What we offer to our clients",
    "level": "h2",
    "alignment": "center",
    "divider": "line"
  }
}
