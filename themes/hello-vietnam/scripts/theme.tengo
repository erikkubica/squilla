seed_setting("hv.phone",              "+84 24 3333 0000")
seed_setting("hv.address",            "17 Hang Ca, Old Quarter, Hanoi")
seed_setting("hv.social.instagram",   "https://instagram.com/hellovietnamadventures")
seed_setting("hv.social.tiktok",      "https://tiktok.com/@hellovietnam")
seed_setting("hv.social.whatsapp",    "https://wa.me/84123456789")
seed_setting("hv.social.email",       "mailto:hello@hellovietnam.travel")
seed_setting("hv.license",            "Registered tour operator · License #HN-2021-0847")
seed_setting("hv.copyright_owner",    "Hello Vietnam Adventures")
seed_setting("hv.impact_percent",     "5%")
seed_setting("hv.copyright_year",     "2026")
seed_setting("hv.lead_magnet.title",  "The Hanoi Street Food Map.")
seed_setting("hv.lead_magnet.body",   "Every dish worth a detour, every egg-coffee den we actually love, 12 laminated-ready pages. Numbered and sortable by district.")
seed_setting("hv.lead_magnet.cta",    "Send me the map")
log.info("Hello Vietnam: hv.* settings seeded")

// ─── Demo Node Seeding ───────────────────────────────────────
seed := func(node_type, label, items) {
	res := nodes.query({ node_type: node_type, limit: 1 })
	if res.total > 0 {
		log.info("Hello Vietnam seed: " + label + " already exist, skipping")
		return
	}
	log.info("Hello Vietnam seed: creating " + label + "...")
	for item in items {
		item.node_type = node_type
		item.status = "published"
		nodes.create(item)
	}
	log.info("Hello Vietnam seed: " + string(len(items)) + " " + label + " created")
}

// Trips — mirrored from components/shared.jsx TRIPS array.
