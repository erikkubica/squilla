// theme.tengo — Hello Vietnam Adventures theme entry point.
// Registers node types, taxonomies, seeds demo content (trips, crew, testimonials, gallery),
// and seeds a demo node per public route.

log := import("core/log")
nodetypes := import("core/nodetypes")
taxonomies := import("core/taxonomies")
nodes := import("core/nodes")
filters := import("core/filters")
settings := import("core/settings")

log.info("Hello Vietnam theme initializing...")

// ─── Taxonomies ──────────────────────────────────────────────
taxonomies.register({
	slug: "trip_tag",
	label: "Trip Tag",
	label_plural: "Trip Tags",
	description: "Foodie / Adventure / Relaxing",
	hierarchical: false,
	node_types: ["trip"]
})

taxonomies.register({
	slug: "gallery_category",
	label: "Gallery Category",
	label_plural: "Gallery Categories",
	description: "Street Food / Landscapes / People / Workshops",
	hierarchical: false,
	node_types: ["gallery_photo"]
})

// ─── Node Types ──────────────────────────────────────────────
nodetypes.register({
	slug: "trip",
	label: "Trip",
	label_plural: "Trips",
	icon: "map",
	description: "A bookable small-group adventure",
	url_prefixes: { en: "trips" },
	field_schema: [
		{ name: "tag",        label: "Tag",               type: "text",     help: "Foodie / Adventure / Relaxing" },
		{ name: "duration",   label: "Duration",          type: "text" },
		{ name: "price",      label: "Price (USD)",       type: "number" },
		{ name: "location",   label: "Location",          type: "text" },
		{ name: "rating",     label: "Rating",            type: "number" },
		{ name: "reviews",    label: "Review Count",      type: "number" },
		{ name: "staff_pick", label: "Staff Pick",        type: "checkbox" },
		{ name: "color",      label: "Accent",            type: "text",     help: "red | yellow | green" },
		{ name: "short",      label: "Short Description", type: "textarea" },
		{ name: "hero_image", label: "Hero Image",        type: "image" },
		{ name: "stops",      label: "Stops",             type: "repeater",
			sub_fields: [
				{ name: "title", label: "Stop Title", type: "text" },
				{ name: "brief", label: "Brief",      type: "textarea" }
			]
		},
		{ name: "included",     label: "What's Included",     type: "repeater",
			sub_fields: [ { name: "item", label: "Item", type: "text" } ]
		},
		{ name: "not_included", label: "What's Not Included", type: "repeater",
			sub_fields: [ { name: "item", label: "Item", type: "text" } ]
		},
		{ name: "faqs",         label: "Quick FAQs",          type: "repeater",
			sub_fields: [
				{ name: "q", label: "Question", type: "text" },
				{ name: "a", label: "Answer",   type: "textarea" }
			]
		}
	],
	taxonomies: ["trip_tag"]
})

nodetypes.register({
	slug: "crew_member",
	label: "Crew Member",
	label_plural: "Crew",
	icon: "users",
	description: "A Hello Vietnam guide or staff member",
	field_schema: [
		{ name: "role",   label: "Role",      type: "text" },
		{ name: "based",  label: "Based In",  type: "text" },
		{ name: "fun",    label: "Fun Fact",  type: "text" },
		{ name: "color",  label: "Accent",    type: "text", help: "red | yellow | green" },
		{ name: "photo",  label: "Photo",     type: "image" }
	]
})

nodetypes.register({
	slug: "testimonial",
	label: "Testimonial",
	label_plural: "Testimonials",
	icon: "message-circle",
	description: "Traveler testimonial",
	field_schema: [
		{ name: "quote",  label: "Quote",  type: "textarea" },
		{ name: "author", label: "Author", type: "text" },
		{ name: "handle", label: "Handle", type: "text" },
		{ name: "color",  label: "Accent", type: "text", help: "red | yellow | green" },
		{ name: "photo",  label: "Photo",  type: "image" }
	]
})

nodetypes.register({
	slug: "gallery_photo",
	label: "Gallery Photo",
	label_plural: "Gallery Photos",
	icon: "image",
	description: "An image for the public gallery",
	field_schema: [
		{ name: "caption",  label: "Caption",           type: "text" },
		{ name: "category", label: "Category",          type: "text", help: "Street Food | Landscapes | People | Workshops" },
		{ name: "color",    label: "Placeholder Color", type: "text", help: "red | yellow | green | ink" },
		{ name: "tall",     label: "Tall Tile",         type: "checkbox", help: "340px if true, 240px if false" },
		{ name: "photo",    label: "Photo",             type: "image" }
	],
	taxonomies: ["gallery_category"]
})

log.info("Hello Vietnam: 4 custom node types registered")

// ─── Filters ─────────────────────────────────────────────────
filters.add("list_nodes",     "./filters/list_nodes")
filters.add("distinct_field", "./filters/distinct_field")
log.info("Hello Vietnam: filters registered (list_nodes, distinct_field)")

// ─── Site Settings (hv.* namespace) ──────────────────────────
// Seeded once so blocks / partials can read shared values via
// {{index .app.settings "hv.key"}}. Editors override via the admin.
seed_setting := func(key, value) {
	existing := settings.get(key)
	if existing == "" || is_error(existing) {
		settings.set(key, value)
	}
}

seed_setting("hv.site_tagline",       "Small-group, locally-guided adventures across Vietnam. Zero tourist traps, maximum laughter.")
seed_setting("hv.primary_cta_label",  "Find Your Adventure →")
seed_setting("hv.primary_cta_url",    "/trips")
seed_setting("hv.trust_rating",       "4.9")
seed_setting("hv.trust_count",        "2,400+")
seed_setting("hv.trust_platform",     "TripAdvisor")
seed_setting("hv.whatsapp",           "+84 12 3456 7890")
