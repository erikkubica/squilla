        "color": "green",
        "icon": "trail"
      },
      {
        "title": "Relaxing",
        "tag": {
          "name": "Relaxing",
          "slug": "relaxing"
        },
        "cta_label": "Explore",
        "color": "yellow",
        "icon": "workshop"
      },
      {
        "title": "Family Fun",
        "tag": {
          "name": "Family Fun",
          "slug": "family_fun"
        },
