{
  "slug": "hv-categories",
  "name": "Home Categories Strip",
  "description": "Hello Vietnam \u2014 Home Categories Strip",
  "category": "hello-vietnam",
  "field_schema": [
    {
      "key": "items",
      "label": "Category Tiles",
      "type": "repeater",
      "help": "Four tiles fit the strip best.",
      "sub_fields": [
        {
          "key": "title",
          "label": "Title",
          "type": "text"
        },
        {
          "key": "tag",
          "label": "Trip Tag",
          "type": "term",
          "taxonomy": "trip_tag",
          "term_node_type": "trip",
          "help": "Pick a trip tag. Link auto-points to /trips?tag=<name>."
        },
        {
          "key": "cta_label",
          "label": "CTA Label",
          "type": "text",
          "help": "Text before the arrow (defaults to \"Explore\")."
        },
        {
          "key": "link",
          "label": "Override Link (optional)",
          "type": "link",
          "help": "Only used when Trip Tag is empty."
        },
        {
          "key": "color",
          "label": "Bubble Color",
          "type": "select",
          "options": [
            "red",
            "green",
            "yellow",
            "ink"
          ]
        },
        {
          "key": "icon",
          "label": "Icon",
          "type": "select",
          "options": [
            "fork",
            "trail",
            "workshop",
            "family"
          ]
        }
      ]
    }
  ],
  "test_data": {
    "items": [
      {
