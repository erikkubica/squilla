{
  "category": "hello-vietnam",
  "description": "A dynamic, Pinterest-style grid of photos arranged in columns of varying heights. Photos can be filtered by category using the Gallery Intro block.",
  "fields": [
    {
      "description": "Each tile is a single photo with optional caption, category and visual options.",
      "fields": [
        {
          "description": "Pick an image from the media library.",
          "name": "photo",
          "title": "Photo",
          "type": "image"
        },
        {
          "description": "Shown when no image is set, and used as the photo alt text.",
          "name": "caption",
          "title": "Caption",
          "type": "string"
        },
        {
          "description": "Used by the filter pills (e.g. Street Food | Landscapes | People | Workshops).",
          "name": "category",
          "title": "Category",
          "type": "string"
        },
        {
          "description": "Tile background color shown when no photo is set.",
          "name": "color",
          "options": [
            "red",
            "yellow",
            "green",
            "ink"
          ],
          "title": "Placeholder Color",
          "type": "select"
        },
        {
          "description": "Render this tile at 340px instead of 240px for visual variety.",
          "name": "tall",
          "title": "Tall Tile",
          "type": "checkbox"
        }
      ],
      "name": "photos",
      "title": "Photos",
      "type": "array"
    }
  ],
