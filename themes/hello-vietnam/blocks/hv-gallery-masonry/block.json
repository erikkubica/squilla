{
  "slug": "hv-gallery-masonry",
  "name": "Gallery Masonry",
  "description": "A dynamic, Pinterest-style grid of photos arranged in columns of varying heights. Photos can be filtered by category using the Gallery Intro block.",
  "category": "hello-vietnam",
  "field_schema": [
    {
      "key": "photos",
      "label": "Photos",
      "type": "repeater",
      "help": "Each tile is a single photo with optional caption, category and visual options.",
      "sub_fields": [
        {
          "key": "photo",
          "label": "Photo",
          "type": "image",
          "help": "Pick an image from the media library."
        },
        {
          "key": "caption",
          "label": "Caption",
          "type": "text",
          "help": "Shown when no image is set, and used as the photo alt text."
        },
        {
          "key": "category",
          "label": "Category",
          "type": "text",
          "help": "Used by the filter pills (e.g. Street Food | Landscapes | People | Workshops)."
        },
        {
          "key": "color",
          "label": "Placeholder Color",
          "type": "select",
          "options": ["red", "yellow", "green", "ink"],
          "help": "Tile background color shown when no photo is set."
        },
        {
          "key": "tall",
          "label": "Tall Tile",
          "type": "checkbox",
          "help": "Render this tile at 340px instead of 240px for visual variety."
        }
      ]
    }
  ],
