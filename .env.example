# Squilla Configuration
# Copy to .env and fill in values

# Server
PORT=8080
APP_ENV=development

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=squilla
DB_PASSWORD=squilla_secret
DB_NAME=squilla
DB_SSLMODE=disable

# Auth
SESSION_SECRET=change-me-to-a-random-64-char-string
SESSION_EXPIRY_HOURS=24

# Monitoring API
MONITOR_BEARER_TOKEN=change-me-to-a-random-token

# At-rest encryption master key (AES-256-GCM)
# MUST be a base64 string that decodes to exactly 32 raw bytes.
# Generate with: openssl rand -base64 32
# Verify: echo -n "$SQUILLA_SECRET_KEY" | base64 -d | wc -c   # → 32
# In dev (APP_ENV=development), if unset, secret settings are stored in plaintext.
# In production, the app refuses to boot without it.
SQUILLA_SECRET_KEY=

# Storage (local or s3)
STORAGE_DRIVER=local
STORAGE_PATH=./storage

# S3 (if STORAGE_DRIVER=s3)
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT=

# AI Provider (openai or anthropic)
AI_PROVIDER=
AI_API_KEY=

# Mail (resend or smtp)
MAIL_PROVIDER=
RESEND_API_KEY=
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
